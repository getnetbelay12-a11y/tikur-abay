{
  "info": {
    "name": "Tikur Abay Transport API",
    "_postman_id": "7bb9e5d3-a6e8-43bf-a555-demo-tikur-abay",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"superadmin@tikurabay.et\",\n  \"password\": \"DemoPass123!\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Operations Dashboard",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/dashboard/operations",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "dashboard",
            "operations"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4001"
    }
  ]
}

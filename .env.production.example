NODE_ENV=production
PORT=6012

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tikur_abay_prod?retryWrites=true&w=majority
MONGO_URI=

JWT_ACCESS_SECRET=replace-with-long-random-production-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-production-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

FRONTEND_URL=https://console.tikurabay.example
API_PUBLIC_URL=https://api.tikurabay.example/api/v1

MAP_PROVIDER=mapbox
MAPBOX_PUBLIC_TOKEN=replace-with-production-mapbox-public-token
GOOGLE_MAPS_API_KEY=

FILE_STORAGE_MODE=s3
LOCAL_STORAGE_DIR=var/uploads
S3_ENDPOINT=https://minio.tikurabay.example
S3_BUCKET=tikur-abay-prod-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=replace-with-production-s3-access-key
S3_SECRET_KEY=replace-with-production-s3-secret-key

REDIS_URL=redis://prod-redis:6379

CORS_ORIGINS=https://console.tikurabay.example,https://customer.tikurabay.example
NEXT_PUBLIC_API_URL=https://api.tikurabay.example/api/v1
NEXT_PUBLIC_API_HEALTH_URL=https://api.tikurabay.example/api/v1/health
ALLOW_DEBUG_OTP=false
ALLOW_DEMO_SCENARIO_TOOLS=false
